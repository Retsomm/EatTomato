{
  "name": "eat-tomato",
  "private": true,
  "version": "1.0.7",
  "description": "番茄鐘桌面應用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.electron.json -w --preserveWatchOutput\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json && electron-builder",
    "release": "vite build && tsc -p tsconfig.electron.json && electron-builder --publish always",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.eattomato.app",
    "productName": "EatTomato",
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/logo.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/assets/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/logo.png"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
